{
    "editor.lineHeight": 2,
    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
    },
    "workbench.iconTheme": "material-icon-theme",
    "editor.stickyScroll.enabled": false,
    "editor.stickyScroll.scrollWithEditor": false,
    "workbench.tree.enableStickyScroll": false,
    "terminal.integrated.stickyScroll.enabled": false,
    "workbench.settings.applyToAllProfiles": [],
    "[vue]": {
        "editor.defaultFormatter": "Vue.volar"
    },
    "redhat.telemetry.enabled": true,
    "git.openRepositoryInParentFolders": "never",
    "workbench.startupEditor": "none",
    "security.workspace.trust.untrustedFiles": "open",
    "files.saveConflictResolution": "overwriteFileOnDisk",
    "chat.viewSessions.orientation": "stacked",
    "editor.cursorBlinking": "expand",
    "editor.cursorStyle": "block",
    "workbench.colorCustomizations": {
        "titleBar.activeBackground": "#191919",
        "titleBar.activeForeground": "#ffffff",
        "menu.background": "#191919",
        "menu.foreground": "#bbbbbb",
        "menu.selectionBackground": "#ff8800",
        "menu.selectionForeground": "#ffffff",
        "menu.separatorBackground": "#808080",
        "menubar.selectionBackground": "#ff8800",
        "activityBar.foreground": "#ffffff",
        "activityBar.background": "#262626",
        "activityBar.inactiveForeground": "#aaaaaa",
        "activityBar.activeBackground": "#444444",
        "activityBarBadge.foreground": "#ffffff",
        "activityBarBadge.background": "#ffaa00",
        "tab.activeBackground": "#333333",
        "tab.activeForeground": "#ffffff",
        "tab.unfocusedActiveBackground": "#000000",
        "tab.inactiveBackground": "#191919",
        "tab.inactiveForeground": "#bbbbbb",
        "tab.hoverForeground": "#ffffff",
        "tab.hoverBackground": "#ff8800",
        "tab.activeBorder": "#191919",
        "tab.activeBorderTop": "#191919",
        "tab.border": "#484a50",
        "tab.hoverBorder": "#191919",
        "editorGroupHeader.tabsBackground": "#191919",
        "editorPane.background": "#ff000000",
        "statusBar.background": "#191919",
        "statusBar.foreground": "#505158",
        "statusBarItem.hoverBackground": "#ff8800",
        "statusBar.debuggingBackground": "#263238",
        "statusBar.noFolderBackground": "#1a1a1a",
        "list.hoverBackground": "#ff8800",
        "list.hoverForeground": "#ffffff",
        "sideBar.background": "#191919",
        "sideBar.foreground": "#999999",
        "sideBarSectionHeader.background": "#191919",
        "sideBarSectionHeader.foreground": "#cccccc",
        "sideBarTitle.foreground": "#ffffff",
        "sideBarSectionHeader.border": "#494949",
        "sideBar.border": "#191919",
        "editor.background": "#262626",
        "editor.foreground": "#ffffff",
        "editorLineNumber.foreground": "#505050",
        "editorLineNumber.activeForeground": "#ff8800",
        "editorLineNumber.dimmedForeground": "#0099ff00",
        "editor.lineHighlightBackground": "#3b3e476e",
        "editor.selectionBackground": "#999b8d",
        "editor.selectionForeground": "#ffffff00",
        "editor.inactiveSelectionBackground": "#ffffff00",
        "editor.wordHighlightBackground": "#00a38200",
        "editor.wordHighlightStrongBackground": "#ffffff00",
        "editor.wordHighlightBorder": "#ffffff00",
        "editor.wordHighlightStrongBorder": "#9daebd",
        "editorBracketMatch.background": "#ffffff00",
        "editorBracketMatch.border": "#ff000000",
        "minimap.background": "#191919a1",
        "minimap.foregroundOpacity": "#000000b2",
        "minimapSlider.background": "#ffffff00",
        "minimapSlider.activeBackground": "#44aacc1f",
        "minimapSlider.hoverBackground": "#44aacc1f",
        "minimap.selectionOccurrenceHighlight": "#00ccff9f",
        "minimap.selectionHighlight": "#7c7c7c7c",
        "minimap.errorHighlight": "#ff3c00",
        "minimap.warningHighlight": "#ffc400",
        "focusBorder": "#ff880000",
        "quickInput.background": "#191919",
        "editorWidget.foreground": "#cccccc",
        "editorWidget.background": "#191919",
        "editorLightBulb.foreground": "#ffd000",
        "editorLightBulbAutoFix.foreground": "#7be732",
        "notificationsErrorIcon.foreground": "#0099ff",
        "notificationsInfoIcon.foreground": "#9900ff",
        "notificationsWarningIcon.foreground": "#ff7300",
        "problemsErrorIcon.foreground": "#0099ff",
        "problemsWarningIcon.foreground": "#ff7300",
        "problemsInfoIcon.foreground": "#9900ff",
        "editorCursor.foreground": "#ff8800"
    },
    "editor.tokenColorCustomizations": {
        "comments": "#666666",
        "numbers": "#44aacc",
        "strings": "#4aff59",
        "textMateRules": [
            {
                "name": "Comment",
                "scope": ["comment", "comment.block", "comment.block.documentation", "comment.line", "comment.line.double-slash", "punctuation.definition.comment"],
                "settings": {
                    "fontStyle": "italic"
                }
            },
            {
                "scope": ["keyword.operator.comparison"],
                "settings": {
                    "foreground": "#ffffff",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": ["storage.type.function.arrow"],
                "settings": {
                    "foreground": "#ffffff",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": ["storage.type.function"],
                "settings": {
                    "foreground": "#44aacc",
                    "fontStyle": "italic bold"
                }
            },
            {
                "scope": ["storage.modifier.async"],
                "settings": {
                    "foreground": "#ff8800"
                }
            }
        ]
    },
    "zenMode.hideLineNumbers": false,
    "window.zoomLevel": 0.1,
    "svelte.enable-ts-plugin": true,
    "css.format.preserveNewLines": false,
    "[svelte]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "prettier.printWidth": 500,
    "prettier.tabWidth": 4,
    "svelte.plugin.svelte.format.config.printWidth": 500,
    "prettier.bracketSameLine": true,
    "prettier.htmlWhitespaceSensitivity": "ignore",
    "explorer.compactFolders": false,
    "workbench.tree.indent": 12
}
